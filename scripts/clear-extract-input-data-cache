#!/bin/bash
# Run from the repository root. Clears the local GCS mirror under bedrock/extract/input_data/.
echo "Clearing bedrock/extract/input_data cache - files to delete:"
find . -type f -path '*bedrock/extract/input_data/*' \
    -not -path '*/.*' \
    -print | sort -n
echo
read -p "Are you sure? [y/n] " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]
then
    find . -type f -path '*bedrock/extract/input_data/*' \
        -not -path '*/.*' \
        -print -delete | sort -n
    echo "Cleared bedrock/extract/input_data cache."
else
    echo "Not clearing cache."
fi
